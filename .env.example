# Local development only. Copy to .env and replace the password locally.
AFFILIATE_DB_NAME=affiliate_global
AFFILIATE_DB_USER=affiliate_app
AFFILIATE_DB_PASSWORD=replace-with-a-local-random-password
AFFILIATE_DB_PORT=5433

# Application connection contract (derive from the values above locally).
DATABASE_URL=postgresql://affiliate_app:replace-with-a-local-random-password@localhost:5433/affiliate_global?schema=public

