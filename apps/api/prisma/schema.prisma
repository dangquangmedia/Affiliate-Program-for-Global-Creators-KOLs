// Schema LEAN N5 — 18 bảng suy từ 12 màn mockup (xem docs/DATA_MODEL.md).
// Thay hoàn toàn schema 45-bảng cũ. Mỗi bảng có 1 màn mockup "đòi" nó ra.
// 3 luật xuyên suốt: tiền = *_minor BigInt + currency; country scope; ledger/audit append-only.

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

// ---------- Enums ----------
enum RoleCode {
  LOCAL_OPS
  LOCAL_FINANCE
  LOCAL_ADMIN
  GLOBAL_ADMIN
}

enum KycCaseState {
  DRAFT
  SUBMITTED
  RESUBMITTED
  APPROVED
  REJECTED
}

enum KycFieldState {
  EMPTY
  FILLED
  ACCEPTED
  NEEDS_CHANGES
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  ENDED
}

enum TriggerType {
  CONTENT_APPROVED
  VIEW_THRESHOLD
  PAID_ORDER
}

enum PricingType {
  FLAT
  TIERED
  PERCENT
}

enum CapType {
  SLOTS_X_PRICE
  POOL
}

enum ParticipationState {
  JOINED
  CONTENT_SUBMITTED
  APPROVED
  REJECTED
  LEFT
}

enum SubmissionState {
  SUBMITTED
  APPROVED
  REJECTED
}

enum EarningStatus {
  PENDING
  AVAILABLE
  PAID
  REVERSED
}

enum LedgerEntryType {
  EARNING_ACCRUE
  TAX
  PAYOUT_RESERVE
  PAYOUT_PAID
  PAYOUT_RELEASE
  REVERSAL
}

enum BatchStatus {
  OPEN
  LOCKED
}

enum PayoutState {
  PROCESSING
  PAID
  FAILED_RELEASED
  UNKNOWN_HOLD
}

enum PayoutAttemptResult {
  SUCCESS
  FAIL
  UNKNOWN
}

enum OtpPurpose {
  PAYOUT
}

// ===== Nhóm A — Danh tính & nền quốc gia =====

// 1. users — danh tính toàn cục, 1 người = 1 tài khoản (V01 login SSO mock).
model User {
  id              String                  @id @default(uuid()) @db.Uuid
  email           String                  @unique
  displayName     String                  @map("display_name")
  authProvider    String                  @map("auth_provider")
  providerSubject String                  @map("provider_subject")
  createdAt       DateTime                @default(now()) @map("created_at") @db.Timestamptz(3)
  profiles        CreatorCountryProfile[]
  roleAssignments RoleAssignment[]
  otpCodes        OtpCode[]
  auditEvents     AuditEvent[]

  @@unique([authProvider, providerSubject]) // 1 danh tính SSO không tạo 2 tài khoản
  @@map("app_user")
}

// 2. countries — bảng neo mọi cách ly. Phase 1: VN, PH. (nút đổi VN/PH mọi màn)
model Country {
  id               String                @id @default(uuid()) @db.Uuid
  code             String                @unique @db.Char(2)
  name             String
  currencyCode     String                @map("currency_code") @db.Char(3)
  currencyExponent Int                   @map("currency_exponent") @db.SmallInt
  locale           String
  fallbackLocale   String                @default("en") @map("fallback_locale")
  enabled          Boolean               @default(true)
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  config           CountryConfig?
  roleAssignments  RoleAssignment[]
  profiles         CreatorCountryProfile[]
  campaigns        Campaign[]
  participations   Participation[]
  earnings         Earning[]
  ledgerEntries    LedgerEntry[]
  batches          ReconciliationBatch[]
  payoutRequests   PayoutRequest[]
  auditEvents      AuditEvent[]

  @@map("country")
}

// 3. country_configs — tham số vận hành từng nước, Global Admin chỉnh (V09).
model CountryConfig {
  id             String   @id @default(uuid()) @db.Uuid
  countryId      String   @unique @map("country_id") @db.Uuid // 1 nước đúng 1 config hiệu lực
  taxPercent     Int      @map("tax_percent") // thuế synthetic demo (VN 10, PH 8)
  minPayoutMinor BigInt   @map("min_payout_minor")
  featureKyc     Boolean  @default(true) @map("feature_kyc")
  featurePayout  Boolean  @default(true) @map("feature_payout")
  featureCps     Boolean  @default(false) @map("feature_cps")
  configVersion  Int      @default(1) @map("config_version")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  country        Country  @relation(fields: [countryId], references: [id], onDelete: Restrict)

  @@map("country_config")
}

// 4. role_assignments — RBAC 4 vai + phạm vi nước (điểm ENFORCE cách ly staff).
model RoleAssignment {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  countryId String?  @map("country_id") @db.Uuid // NULL cho GLOBAL_ADMIN
  role      RoleCode
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  country   Country? @relation(fields: [countryId], references: [id], onDelete: Restrict)

  @@unique([userId, countryId, role]) // không cấp trùng vai
  @@index([countryId, role])
  @@map("role_assignment")
}

// ===== Nhóm B — Creator onboarding =====

// 5. creator_country_profiles — hồ sơ creator RIÊNG từng nước (V02). Mỏ neo dữ liệu creator.
model CreatorCountryProfile {
  id              String          @id @default(uuid()) @db.Uuid
  userId          String          @map("user_id") @db.Uuid
  countryId       String          @map("country_id") @db.Uuid
  onboardingState String          @default("NEW") @map("onboarding_state")
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  user            User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  country         Country         @relation(fields: [countryId], references: [id], onDelete: Restrict)
  kycCase         KycCase?
  participations  Participation[]
  earnings        Earning[]
  ledgerEntries   LedgerEntry[]
  payoutRequests  PayoutRequest[]

  @@unique([userId, countryId]) // 1 tài khoản không tạo 2 hồ sơ cùng nước
  @@index([countryId])
  @@map("creator_country_profile")
}

// 6. kyc_cases — hồ sơ định danh của 1 profile, có máy trạng thái (V03/V10). Cổng chặn Join.
model KycCase {
  id         String       @id @default(uuid()) @db.Uuid
  profileId  String       @unique @map("profile_id") @db.Uuid // mỗi hồ sơ nước đúng 1 case
  state      KycCaseState @default(DRAFT)
  reviewedBy String?      @map("reviewed_by") @db.Uuid
  reviewedAt DateTime?    @map("reviewed_at") @db.Timestamptz(3)
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)
  profile    CreatorCountryProfile @relation(fields: [profileId], references: [id], onDelete: Restrict)
  fields     KycField[]

  @@map("kyc_case")
}

// 7. kyc_fields — từng trường KYC + trạng thái + lý do (duyệt/từ chối THEO trường).
model KycField {
  id     String        @id @default(uuid()) @db.Uuid
  caseId String        @map("case_id") @db.Uuid
  key    String
  label  String
  value  String?
  state  KycFieldState @default(EMPTY)
  reason String? // chỉ khi NEEDS_CHANGES
  case   KycCase       @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@unique([caseId, key]) // mỗi trường đúng 1 dòng
  @@map("kyc_field")
}

// ===== Nhóm C — Campaign & tham gia =====

// 8. campaigns — chiến dịch, gắn ĐÚNG 1 nước (V04/V05/V11). "Đầy" = suy ra, không lưu.
model Campaign {
  id              String         @id @default(uuid()) @db.Uuid
  countryId       String         @map("country_id") @db.Uuid
  brand           String
  title           String
  rewardMinor     BigInt         @map("reward_minor")
  currency        String         @db.Char(3) // PHẢI = currency của country
  slotsTotal      Int            @map("slots_total")
  slotsTaken      Int            @default(0) @map("slots_taken")
  status          CampaignStatus @default(ACTIVE)
  platform        String
  requiredHashtag String         @map("required_hashtag")
  brief           String
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  country         Country        @relation(fields: [countryId], references: [id], onDelete: Restrict)
  rewardRule      RewardRule?
  participations  Participation[]

  @@index([countryId, status])
  @@map("campaign")
}

// 9. reward_rules — quy tắc thưởng 3 TRỤC, tách khỏi campaign (V11). Phase 1: CONTENT_APPROVED+FLAT.
model RewardRule {
  id              String      @id @default(uuid()) @db.Uuid
  campaignId      String      @unique @map("campaign_id") @db.Uuid
  triggerType     TriggerType @map("trigger_type")          // ① điều kiện
  viewThreshold   Int?        @map("view_threshold")        // ① NULL trừ VIEW_THRESHOLD
  pricingType     PricingType @map("pricing_type")          // ② định giá
  flatAmountMinor BigInt?     @map("flat_amount_minor")     // ② FLAT
  percentBps      Int?        @map("percent_bps")           // ② % cho CPS sau (chừa đường)
  capType         CapType     @map("cap_type")              // ③ trần ngân sách
  capSlots        Int?        @map("cap_slots")
  capPoolMinor    BigInt?     @map("cap_pool_minor")
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz(3)
  campaign        Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("reward_rule")
}

// 10. participations — giữ 1 suất + SNAPSHOT điều khoản lúc join (V05). Join idempotent.
model Participation {
  id                   String             @id @default(uuid()) @db.Uuid
  profileId            String             @map("profile_id") @db.Uuid
  campaignId           String             @map("campaign_id") @db.Uuid
  countryId            String             @map("country_id") @db.Uuid
  state                ParticipationState @default(JOINED)
  joinedAt             DateTime           @default(now()) @map("joined_at") @db.Timestamptz(3)
  snapshotRewardMinor  BigInt             @map("snapshot_reward_minor")  // earning tính từ đây
  snapshotCurrency     String             @map("snapshot_currency") @db.Char(3)
  snapshotTriggerType  TriggerType        @map("snapshot_trigger_type")
  snapshotPricingType  PricingType        @map("snapshot_pricing_type")
  rowVersion           Int                @default(0) @map("row_version")
  profile              CreatorCountryProfile @relation(fields: [profileId], references: [id], onDelete: Restrict)
  campaign             Campaign           @relation(fields: [campaignId], references: [id], onDelete: Restrict)
  country              Country            @relation(fields: [countryId], references: [id], onDelete: Restrict)
  submissions          Submission[]
  earnings             Earning[]

  @@unique([profileId, campaignId]) // Join idempotent: 2 lần bấm không giữ 2 suất
  @@index([countryId, state])
  @@map("participation")
}

// ===== Nhóm D — Content & duyệt =====

// 11. submissions — mỗi lần nộp content = 1 dòng (append theo attempt) (V06/V10).
model Submission {
  id             String          @id @default(uuid()) @db.Uuid
  participationId String         @map("participation_id") @db.Uuid
  attemptNo      Int             @map("attempt_no")
  supersedesId   String?         @map("supersedes_id") @db.Uuid // trỏ bản bị reject trước
  url            String
  platform       String
  hashtagOk      Boolean         @map("hashtag_ok")
  platformOk     Boolean         @map("platform_ok")
  state          SubmissionState @default(SUBMITTED)
  rejectReason   String?         @map("reject_reason")
  reviewedBy     String?         @map("reviewed_by") @db.Uuid
  reviewedAt     DateTime?       @map("reviewed_at") @db.Timestamptz(3)
  rowVersion     Int             @default(0) @map("row_version") // version check -> 409
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  participation  Participation   @relation(fields: [participationId], references: [id], onDelete: Restrict)
  supersedes     Submission?     @relation("SubmissionChain", fields: [supersedesId], references: [id], onDelete: Restrict)
  supersededBy   Submission[]    @relation("SubmissionChain")
  earning        Earning?

  @@unique([participationId, attemptNo]) // không trùng số lần nộp
  @@map("content_submission")
}

// ===== Nhóm E — Tiền =====

// 12. earnings — thu nhập, sinh ĐÚNG 1 LẦN khi content được duyệt (V07). Khóa quan trọng nhất.
model Earning {
  id             String        @id @default(uuid()) @db.Uuid
  participationId String       @map("participation_id") @db.Uuid
  submissionId   String        @unique @map("submission_id") @db.Uuid // exactly-once earning
  countryId      String        @map("country_id") @db.Uuid
  profileId      String        @map("profile_id") @db.Uuid
  grossMinor     BigInt        @map("gross_minor")
  taxMinor       BigInt        @map("tax_minor") // net = gross - tax (KHÔNG lưu)
  currency       String        @db.Char(3)
  status         EarningStatus @default(PENDING)
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)
  participation  Participation @relation(fields: [participationId], references: [id], onDelete: Restrict)
  submission     Submission    @relation(fields: [submissionId], references: [id], onDelete: Restrict)
  country        Country       @relation(fields: [countryId], references: [id], onDelete: Restrict)
  profile        CreatorCountryProfile @relation(fields: [profileId], references: [id], onDelete: Restrict)
  ledgerEntries  LedgerEntry[]
  reconLine      ReconciliationLine?

  @@index([countryId, profileId, status])
  @@map("earning")
}

// 13. ledger_entries — sổ cái APPEND-ONLY, sự thật cuối cùng về tiền. Không UPDATE/DELETE.
model LedgerEntry {
  id           String          @id @default(uuid()) @db.Uuid
  countryId    String          @map("country_id") @db.Uuid
  profileId    String          @map("profile_id") @db.Uuid
  entryType    LedgerEntryType @map("entry_type")
  amountMinor  BigInt          @map("amount_minor") // CÓ DẤU (+/-)
  currency     String          @db.Char(3)
  refType      String          @map("ref_type") // 'earning' | 'payout' ...
  refId        String          @map("ref_id") @db.Uuid
  reversalOfId String?         @map("reversal_of_id") @db.Uuid
  earningId    String?         @map("earning_id") @db.Uuid
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  country      Country         @relation(fields: [countryId], references: [id], onDelete: Restrict)
  profile      CreatorCountryProfile @relation(fields: [profileId], references: [id], onDelete: Restrict)
  reversalOf   LedgerEntry?    @relation("LedgerReversal", fields: [reversalOfId], references: [id], onDelete: Restrict)
  reversedBy   LedgerEntry[]   @relation("LedgerReversal")
  earning      Earning?        @relation(fields: [earningId], references: [id], onDelete: Restrict)

  @@unique([refType, refId, entryType]) // 1 sự kiện không ghi sổ 2 lần (chống double-pay)
  @@index([countryId, profileId])
  @@map("ledger_entry")
}

// 14. reconciliation_batches — kỳ đối soát, LOCKED = bất biến (V12).
model ReconciliationBatch {
  id        String               @id @default(uuid()) @db.Uuid
  countryId String               @map("country_id") @db.Uuid
  period    String
  status    BatchStatus          @default(OPEN)
  lockedBy  String?              @map("locked_by") @db.Uuid
  lockedAt  DateTime?            @map("locked_at") @db.Timestamptz(3)
  createdAt DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  country   Country              @relation(fields: [countryId], references: [id], onDelete: Restrict)
  lines     ReconciliationLine[]

  @@index([countryId, status])
  @@map("reconciliation_batch")
}

// 15. reconciliation_lines — từng dòng đối soát; 1 earning vào ĐÚNG 1 batch (V12).
model ReconciliationLine {
  id        String              @id @default(uuid()) @db.Uuid
  batchId   String              @map("batch_id") @db.Uuid
  earningId String              @unique @map("earning_id") @db.Uuid // không đối soát/trả 2 lần
  netMinor  BigInt              @map("net_minor")
  currency  String              @db.Char(3)
  anomaly   String?
  createdAt DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  batch     ReconciliationBatch @relation(fields: [batchId], references: [id], onDelete: Restrict)
  earning   Earning             @relation(fields: [earningId], references: [id], onDelete: Restrict)

  @@map("reconciliation_line")
}

// 16. payout_requests — lệnh rút, máy trạng thái 3 kết cục (V08/V12).
model PayoutRequest {
  id             String        @id @default(uuid()) @db.Uuid
  countryId      String        @map("country_id") @db.Uuid
  profileId      String        @map("profile_id") @db.Uuid
  amountMinor    BigInt        @map("amount_minor")
  currency       String        @db.Char(3)
  state          PayoutState   @default(PROCESSING)
  otpId          String?       @map("otp_id") @db.Uuid
  idempotencyKey String        @unique @map("idempotency_key") // bấm rút 2 lần không tạo 2 lệnh
  requestedAt    DateTime      @default(now()) @map("requested_at") @db.Timestamptz(3)
  country        Country       @relation(fields: [countryId], references: [id], onDelete: Restrict)
  profile        CreatorCountryProfile @relation(fields: [profileId], references: [id], onDelete: Restrict)
  otp            OtpCode?      @relation(fields: [otpId], references: [id], onDelete: Restrict)
  attempts       PayoutAttempt[]

  @@index([countryId, profileId, state])
  @@map("payout_request")
}

// 17. payout_attempts — mỗi lần gọi provider mock = 1 dòng. providerRef unique = idempotent.
model PayoutAttempt {
  id              String              @id @default(uuid()) @db.Uuid
  payoutRequestId String              @map("payout_request_id") @db.Uuid
  providerRef     String              @unique @map("provider_ref") // callback/retry chỉ ghi 1 lần
  result          PayoutAttemptResult
  raw             String?
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  request         PayoutRequest       @relation(fields: [payoutRequestId], references: [id], onDelete: Restrict)

  @@map("payout_attempt")
}

// ===== Nhóm F — cắt ngang =====

// 18. otp_codes — OTP mock cho rút tiền (V08). consumed_at => không tái dùng.
model OtpCode {
  id         String     @id @default(uuid()) @db.Uuid
  userId     String     @map("user_id") @db.Uuid
  purpose    OtpPurpose
  code       String
  expiresAt  DateTime   @map("expires_at") @db.Timestamptz(3)
  consumedAt DateTime?  @map("consumed_at") @db.Timestamptz(3)
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  payoutRequests PayoutRequest[]

  @@index([userId, purpose])
  @@map("otp_code")
}

// audit_events — nhật ký mọi quyết định staff (append-only). Cắt ngang mọi màn staff.
model AuditEvent {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String   @map("actor_user_id") @db.Uuid
  countryId   String?  @map("country_id") @db.Uuid
  action      String
  targetType  String?  @map("target_type")
  targetId    String?  @map("target_id") @db.Uuid
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  actor       User     @relation(fields: [actorUserId], references: [id], onDelete: Restrict)
  country     Country? @relation(fields: [countryId], references: [id], onDelete: Restrict)

  @@index([countryId, createdAt])
  @@map("audit_event")
}
