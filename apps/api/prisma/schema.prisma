generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum ProfileStatus {
  ACTIVE
  SUSPENDED
}

enum RoleCode {
  CREATOR
  LOCAL_OPS
  LOCAL_FINANCE
  LOCAL_ADMIN
  GLOBAL_ADMIN
}

enum KycCaseState {
  DRAFT
  SUBMITTED
  IN_REVIEW
  NEEDS_CHANGES
  RESUBMITTED
  APPROVED
  REJECTED
}

enum KycFieldState {
  DRAFT
  SUBMITTED
  ACCEPTED
  NEEDS_CHANGES
  REJECTED
}

enum ReviewTargetType {
  KYC_CASE
  KYC_FIELD
  CONTENT_SUBMISSION
  SUBMISSION_VERSION
}

enum ReviewDecisionType {
  CLAIMED
  ACCEPTED
  NEEDS_CHANGES
  REJECTED
  APPROVED
}

enum CatalogStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum RewardTrigger {
  CONTENT_APPROVED
  PAID_ORDER
  QUALIFIED_LEAD
  APP_INSTALL
  SUBSCRIPTION
}

enum RewardCalculation {
  CONTENT_FLAT
  SALE_PERCENT
  LEAD_FLAT
  INSTALL_FLAT
  RECURRING_FLAT
  RECURRING_PERCENT
}

enum CampaignState {
  DRAFT
  ACTIVE
  PAUSED
  CLOSED
}

enum ParticipationState {
  JOINED
  ACTIVE
  SUSPENDED
  COMPLETED
  CANCELLED
}

enum ContentState {
  DRAFT
  SUBMITTED
  IN_REVIEW
  NEEDS_CHANGES
  REJECTED
  RESUBMITTED
  APPROVED
}

enum EarningState {
  PENDING
  CONFIRMED
  AVAILABLE
  PAID
  REVERSED
}

enum SnapshotKind {
  TERMS
  REWARD
  COMMISSION
  TAX
  FX
  ROUNDING
}

enum LedgerDirection {
  DEBIT
  CREDIT
}

enum BatchState {
  DRAFT
  REVIEWING
  APPROVED
  LOCKED
  EXPORTED
}

enum ReconciliationDecision {
  PENDING
  APPROVED
  ANOMALY
  ADJUSTED
}

enum OtpState {
  OTP_PENDING
  VERIFIED
  EXPIRED
  ATTEMPTS_EXCEEDED
}

enum PayoutState {
  RESERVED
  QUEUED
  PROCESSING
  PAID
  FAILED_FINAL
  UNKNOWN
  REVERSED
}

enum PayoutAttemptState {
  QUEUED
  PROCESSING
  SUCCEEDED
  FAILED_FINAL
  UNKNOWN
}

enum AuditOutcome {
  ATTEMPTED
  SUCCEEDED
  DENIED
  FAILED
}

enum ExternalEventStatus {
  RECEIVED
  APPLIED
  DUPLICATE
  CONFLICT
  FAILED
}

model User {
  id                 String                @id @default(uuid()) @db.Uuid
  status             UserStatus            @default(ACTIVE)
  createdAt          DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)
  identities         IdentityProvider[]
  sessions           Session[]
  profiles           CreatorCountryProfile[]
  roleAssignments    RoleAssignment[]
  reviewDecisions    ReviewDecision[]       @relation("ReviewActor")
  auditEvents        AuditEvent[]
  idempotencyRecords IdempotencyRecord[]

  @@map("app_user")
}

model IdentityProvider {
  id                  String   @id @default(uuid()) @db.Uuid
  userId              String   @map("user_id") @db.Uuid
  provider            String   @db.VarChar(40)
  providerSubjectHash String   @map("provider_subject_hash") @db.VarChar(128)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  user                User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([provider, providerSubjectHash])
  @@index([userId])
  @@map("identity_provider")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash") @db.VarChar(128)
  mfaLevel  String   @default("BASE") @map("mfa_level") @db.VarChar(20)
  expiresAt DateTime @map("expires_at") @db.Timestamptz(3)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(3)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("session")
}

model Country {
  id               String                  @id @default(uuid()) @db.Uuid
  code             String                  @unique @db.Char(2)
  name             String                  @db.VarChar(100)
  currencyCode     String                  @map("currency_code") @db.Char(3)
  currencyExponent Int                     @map("currency_exponent") @db.SmallInt
  enabled          Boolean                 @default(true)
  createdAt        DateTime                @default(now()) @map("created_at") @db.Timestamptz(3)
  configs          CountryConfig[]
  profiles         CreatorCountryProfile[]
  roleAssignments  RoleAssignment[]
  campaigns        Campaign[]
  kycCases         KycCase[]
  participations   Participation[]
  submissions      ContentSubmission[]
  earnings         Earning[]
  ledgerEntries    LedgerEntry[]
  batches          ReconciliationBatch[]
  payoutIntents    PayoutIntent[]
  payoutRequests   PayoutRequest[]
  auditEvents      AuditEvent[]
  externalEvents   ExternalEvent[]

  @@map("country")
}

model CountryConfig {
  id             String   @id @default(uuid()) @db.Uuid
  countryId      String   @map("country_id") @db.Uuid
  version        Int
  locale         String   @db.VarChar(16)
  fallbackLocale String   @default("en") @map("fallback_locale") @db.VarChar(16)
  config         Json     @map("config_json")
  active         Boolean  @default(false)
  activeFrom     DateTime? @map("active_from") @db.Timestamptz(3)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  country        Country  @relation(fields: [countryId], references: [id], onDelete: Restrict)

  @@unique([countryId, version])
  @@index([countryId, active])
  @@map("country_config")
}

model CreatorCountryProfile {
  id                    String              @id @default(uuid()) @db.Uuid
  userId                String              @map("user_id") @db.Uuid
  countryId             String              @map("country_id") @db.Uuid
  displayName           String              @map("display_name") @db.VarChar(120)
  preferredLocale       String              @map("preferred_locale") @db.VarChar(16)
  status                ProfileStatus       @default(ACTIVE)
  bankReferenceEncrypted String?             @map("bank_reference_encrypted") @db.Text
  taxReferenceEncrypted String?              @map("tax_reference_encrypted") @db.Text
  version               Int                 @default(0)
  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)
  user                  User                @relation(fields: [userId], references: [id], onDelete: Restrict)
  country               Country             @relation(fields: [countryId], references: [id], onDelete: Restrict)
  kycCases              KycCase[]
  participations        Participation[]
  payoutIntents         PayoutIntent[]

  @@unique([userId, countryId])
  @@unique([id, countryId])
  @@index([countryId, status, createdAt])
  @@map("creator_country_profile")
}

model RoleAssignment {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  countryId   String?  @map("country_id") @db.Uuid
  role        RoleCode
  permissions String[] @default([])
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  country     Country? @relation(fields: [countryId], references: [id], onDelete: Restrict)

  @@unique([userId, countryId, role])
  @@index([countryId, role])
  @@map("role_assignment")
}

model KycCase {
  id           String        @id @default(uuid()) @db.Uuid
  profileId    String        @map("profile_id") @db.Uuid
  countryId    String        @map("country_id") @db.Uuid
  state        KycCaseState  @default(DRAFT)
  version      Int           @default(0)
  submittedAt  DateTime?     @map("submitted_at") @db.Timestamptz(3)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)
  profile      CreatorCountryProfile @relation(fields: [profileId, countryId], references: [id, countryId], onDelete: Restrict)
  country      Country       @relation(fields: [countryId], references: [id], onDelete: Restrict)
  fields       KycFieldVersion[]
  decisions    ReviewDecision[]

  @@unique([id, countryId])
  @@index([countryId, state, createdAt, id])
  @@map("kyc_case")
}

model KycFieldVersion {
  id        String        @id @default(uuid()) @db.Uuid
  caseId    String        @map("case_id") @db.Uuid
  fieldKey  String        @map("field_key") @db.VarChar(80)
  version   Int
  valueRef  String?       @map("value_ref") @db.Text
  valueHash String?       @map("value_hash") @db.VarChar(128)
  state     KycFieldState @default(DRAFT)
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  kycCase   KycCase       @relation(fields: [caseId], references: [id], onDelete: Restrict)
  decisions ReviewDecision[]

  @@unique([caseId, fieldKey, version])
  @@index([caseId, fieldKey, state])
  @@map("kyc_field_version")
}

model ReviewDecision {
  id               String             @id @default(uuid()) @db.Uuid
  actorUserId      String             @map("actor_user_id") @db.Uuid
  countryId        String             @map("country_id") @db.Uuid
  targetType       ReviewTargetType   @map("target_type")
  targetId         String             @map("target_id") @db.Uuid
  targetVersion    Int?               @map("target_version")
  decision         ReviewDecisionType
  reasonCode       String?            @map("reason_code") @db.VarChar(80)
  reasonText       String?            @map("reason_text") @db.Text
  kycCaseId        String?            @map("kyc_case_id") @db.Uuid
  kycFieldVersionId String?           @map("kyc_field_version_id") @db.Uuid
  submissionId     String?            @map("submission_id") @db.Uuid
  submissionVersionId String?         @map("submission_version_id") @db.Uuid
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  actor            User               @relation("ReviewActor", fields: [actorUserId], references: [id], onDelete: Restrict)
  kycCase          KycCase?           @relation(fields: [kycCaseId], references: [id], onDelete: Restrict)
  kycFieldVersion  KycFieldVersion?   @relation(fields: [kycFieldVersionId], references: [id], onDelete: Restrict)
  submission       ContentSubmission? @relation(fields: [submissionId], references: [id], onDelete: Restrict)
  submissionVersion SubmissionVersion? @relation(fields: [submissionVersionId], references: [id], onDelete: Restrict)

  @@index([countryId, targetType, targetId, createdAt])
  @@map("review_decision")
}

model Partner {
  id        String        @id @default(uuid()) @db.Uuid
  name      String        @db.VarChar(160)
  status    CatalogStatus @default(ACTIVE)
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  products  Product[]

  @@map("partner")
}

model Product {
  id        String        @id @default(uuid()) @db.Uuid
  partnerId String        @map("partner_id") @db.Uuid
  name      String        @db.VarChar(180)
  category  String        @db.VarChar(100)
  status    CatalogStatus @default(DRAFT)
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  partner   Partner       @relation(fields: [partnerId], references: [id], onDelete: Restrict)
  offers    Offer[]

  @@index([partnerId, status])
  @@map("product")
}

model Offer {
  id           String        @id @default(uuid()) @db.Uuid
  productId    String        @map("product_id") @db.Uuid
  termsVersion Int           @map("terms_version")
  terms        Json          @map("terms_json")
  currency     String        @db.Char(3)
  status       CatalogStatus @default(DRAFT)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  product      Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  rewardRules  RewardRule[]
  campaigns    Campaign[]

  @@index([productId, status])
  @@map("offer")
}

model RewardRule {
  id          String            @id @default(uuid()) @db.Uuid
  offerId     String            @map("offer_id") @db.Uuid
  trigger     RewardTrigger
  calculation RewardCalculation
  amountMinor BigInt?           @map("amount_minor")
  rate        Decimal?          @db.Decimal(20, 10)
  version     Int
  active      Boolean           @default(true)
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  offer       Offer             @relation(fields: [offerId], references: [id], onDelete: Restrict)

  @@unique([offerId, version])
  @@map("reward_rule")
}

model Campaign {
  id             String        @id @default(uuid()) @db.Uuid
  offerId        String        @map("offer_id") @db.Uuid
  countryId      String        @map("country_id") @db.Uuid
  state          CampaignState @default(DRAFT)
  startsAt       DateTime      @map("starts_at") @db.Timestamptz(3)
  endsAt         DateTime      @map("ends_at") @db.Timestamptz(3)
  slotCap        Int?          @map("slot_cap")
  budgetMinor    BigInt?       @map("budget_minor")
  currency       String        @db.Char(3)
  version        Int           @default(0)
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)
  offer          Offer         @relation(fields: [offerId], references: [id], onDelete: Restrict)
  country        Country       @relation(fields: [countryId], references: [id], onDelete: Restrict)
  localizations  CampaignLocalization[]
  participations Participation[]

  @@unique([id, countryId])
  @@index([countryId, state, startsAt, endsAt])
  @@map("campaign")
}

model CampaignLocalization {
  id         String   @id @default(uuid()) @db.Uuid
  campaignId String   @map("campaign_id") @db.Uuid
  locale     String   @db.VarChar(16)
  title      String   @db.VarChar(180)
  brief      String   @db.Text
  termsCopy  String   @map("terms_copy") @db.Text
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, locale])
  @@map("campaign_localization")
}

model Participation {
  id          String             @id @default(uuid()) @db.Uuid
  profileId   String             @map("profile_id") @db.Uuid
  campaignId  String             @map("campaign_id") @db.Uuid
  countryId   String             @map("country_id") @db.Uuid
  state       ParticipationState @default(JOINED)
  joinedAt    DateTime           @default(now()) @map("joined_at") @db.Timestamptz(3)
  version     Int                @default(0)
  profile     CreatorCountryProfile @relation(fields: [profileId, countryId], references: [id, countryId], onDelete: Restrict)
  campaign    Campaign           @relation(fields: [campaignId, countryId], references: [id, countryId], onDelete: Restrict)
  country     Country            @relation(fields: [countryId], references: [id], onDelete: Restrict)
  snapshot    ParticipationSnapshot?
  assets      TrackingAsset[]
  submissions ContentSubmission[]

  @@unique([profileId, campaignId])
  @@unique([id, countryId])
  @@index([countryId, state, joinedAt])
  @@map("participation")
}

model ParticipationSnapshot {
  id              String        @id @default(uuid()) @db.Uuid
  participationId String        @unique @map("participation_id") @db.Uuid
  offerVersion    Int           @map("offer_version")
  termsSnapshot   Json          @map("terms_snapshot")
  rewardSnapshot  Json          @map("reward_snapshot")
  commissionSnapshot Json       @map("commission_snapshot")
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  participation   Participation @relation(fields: [participationId], references: [id], onDelete: Restrict)

  @@map("participation_snapshot")
}

model TrackingAsset {
  id              String        @id @default(uuid()) @db.Uuid
  participationId String        @map("participation_id") @db.Uuid
  type            String        @db.VarChar(40)
  publicValue     String        @map("public_value") @db.Text
  valueHash       String        @map("value_hash") @db.VarChar(128)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  participation   Participation @relation(fields: [participationId], references: [id], onDelete: Restrict)

  @@unique([participationId, type])
  @@unique([type, valueHash])
  @@map("tracking_asset")
}

model ContentSubmission {
  id              String        @id @default(uuid()) @db.Uuid
  participationId String        @map("participation_id") @db.Uuid
  countryId       String        @map("country_id") @db.Uuid
  state           ContentState  @default(DRAFT)
  activeVersion   Int?          @map("active_version")
  version         Int           @default(0)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)
  participation   Participation @relation(fields: [participationId, countryId], references: [id, countryId], onDelete: Restrict)
  country         Country       @relation(fields: [countryId], references: [id], onDelete: Restrict)
  versions        SubmissionVersion[]
  decisions       ReviewDecision[]

  @@unique([id, countryId])
  @@index([countryId, state, createdAt, id])
  @@map("content_submission")
}

model SubmissionVersion {
  id           String            @id @default(uuid()) @db.Uuid
  submissionId String            @map("submission_id") @db.Uuid
  version      Int
  contentRef   String            @map("content_ref") @db.Text
  contentHash  String            @map("content_hash") @db.VarChar(128)
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  submission   ContentSubmission @relation(fields: [submissionId], references: [id], onDelete: Restrict)
  decisions    ReviewDecision[]
  earning      Earning?

  @@unique([submissionId, version])
  @@map("submission_version")
}

model Earning {
  id              String            @id @default(uuid()) @db.Uuid
  countryId       String            @map("country_id") @db.Uuid
  profileId       String            @map("profile_id") @db.Uuid
  sourceType      String            @map("source_type") @db.VarChar(60)
  sourceId        String            @unique @map("source_id") @db.Uuid
  submissionVersionId String?       @unique @map("submission_version_id") @db.Uuid
  state           EarningState      @default(PENDING)
  grossMinor      BigInt            @map("gross_minor")
  taxMinor        BigInt            @map("tax_minor")
  netMinor        BigInt            @map("net_minor")
  currency        String            @db.Char(3)
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz(3)
  country         Country           @relation(fields: [countryId], references: [id], onDelete: Restrict)
  submissionVersion SubmissionVersion? @relation(fields: [submissionVersionId], references: [id], onDelete: Restrict)
  snapshots       EarningSnapshot[]
  ledgerEntries   LedgerEntry[]
  reconciliationLines ReconciliationLine[]

  @@unique([sourceType, sourceId])
  @@unique([id, countryId])
  @@index([countryId, profileId, state, createdAt])
  @@map("earning")
}

model EarningSnapshot {
  id          String       @id @default(uuid()) @db.Uuid
  earningId   String       @map("earning_id") @db.Uuid
  kind        SnapshotKind
  ruleVersion String       @map("rule_version") @db.VarChar(80)
  value       Json         @map("value_json")
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  earning     Earning      @relation(fields: [earningId], references: [id], onDelete: Restrict)

  @@unique([earningId, kind])
  @@map("earning_snapshot")
}

model LedgerEntry {
  id              String          @id @default(uuid()) @db.Uuid
  countryId       String          @map("country_id") @db.Uuid
  transactionKey  String          @map("transaction_key") @db.VarChar(128)
  effectKey       String          @unique @map("effect_key") @db.VarChar(180)
  account         String          @db.VarChar(80)
  direction       LedgerDirection
  amountMinor     BigInt          @map("amount_minor")
  currency        String          @db.Char(3)
  earningId       String?         @map("earning_id") @db.Uuid
  payoutRequestId String?         @map("payout_request_id") @db.Uuid
  reversesEntryId String?         @map("reverses_entry_id") @db.Uuid
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  country         Country         @relation(fields: [countryId], references: [id], onDelete: Restrict)
  earning         Earning?        @relation(fields: [earningId], references: [id], onDelete: Restrict)
  payoutRequest   PayoutRequest?  @relation(fields: [payoutRequestId], references: [id], onDelete: Restrict)
  reversesEntry   LedgerEntry?    @relation("LedgerReversal", fields: [reversesEntryId], references: [id], onDelete: Restrict)
  reversedBy      LedgerEntry[]   @relation("LedgerReversal")

  @@index([countryId, transactionKey])
  @@index([countryId, earningId])
  @@index([countryId, payoutRequestId])
  @@map("ledger_entry")
}

model ReconciliationBatch {
  id          String        @id @default(uuid()) @db.Uuid
  countryId   String        @map("country_id") @db.Uuid
  currency    String        @db.Char(3)
  periodStart DateTime      @map("period_start") @db.Timestamptz(3)
  periodEnd   DateTime      @map("period_end") @db.Timestamptz(3)
  state       BatchState    @default(DRAFT)
  version     Int           @default(0)
  lockedAt    DateTime?     @map("locked_at") @db.Timestamptz(3)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  country     Country       @relation(fields: [countryId], references: [id], onDelete: Restrict)
  lines       ReconciliationLine[]

  @@unique([id, countryId])
  @@index([countryId, state, createdAt])
  @@map("reconciliation_batch")
}

model ReconciliationLine {
  id          String                 @id @default(uuid()) @db.Uuid
  batchId     String                 @map("batch_id") @db.Uuid
  earningId   String                 @map("earning_id") @db.Uuid
  countryId   String                 @map("country_id") @db.Uuid
  decision    ReconciliationDecision @default(PENDING)
  amountMinor BigInt                 @map("amount_minor")
  currency    String                 @db.Char(3)
  reasonCode  String?                @map("reason_code") @db.VarChar(80)
  createdAt   DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)
  batch       ReconciliationBatch    @relation(fields: [batchId, countryId], references: [id, countryId], onDelete: Restrict)
  earning     Earning                @relation(fields: [earningId, countryId], references: [id, countryId], onDelete: Restrict)

  @@unique([batchId, earningId])
  @@index([countryId, decision])
  @@map("reconciliation_line")
}

model PayoutIntent {
  id             String                @id @default(uuid()) @db.Uuid
  profileId      String                @map("profile_id") @db.Uuid
  countryId      String                @map("country_id") @db.Uuid
  state          OtpState              @default(OTP_PENDING)
  otpHash        String                @map("otp_hash") @db.VarChar(128)
  attempts       Int                   @default(0)
  expiresAt      DateTime              @map("expires_at") @db.Timestamptz(3)
  verifiedAt     DateTime?             @map("verified_at") @db.Timestamptz(3)
  createdAt      DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  profile        CreatorCountryProfile @relation(fields: [profileId, countryId], references: [id, countryId], onDelete: Restrict)
  country        Country               @relation(fields: [countryId], references: [id], onDelete: Restrict)
  request        PayoutRequest?

  @@unique([id, countryId])
  @@index([countryId, profileId, state, createdAt])
  @@map("payout_intent")
}

model PayoutRequest {
  id             String          @id @default(uuid()) @db.Uuid
  intentId       String          @unique @map("intent_id") @db.Uuid
  countryId      String          @map("country_id") @db.Uuid
  profileId      String          @map("profile_id") @db.Uuid
  state          PayoutState     @default(RESERVED)
  amountMinor    BigInt          @map("amount_minor")
  currency       String          @db.Char(3)
  reservedAt     DateTime        @default(now()) @map("reserved_at") @db.Timestamptz(3)
  releasedAt     DateTime?       @map("released_at") @db.Timestamptz(3)
  paidAt         DateTime?       @map("paid_at") @db.Timestamptz(3)
  version        Int             @default(0)
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  intent         PayoutIntent    @relation(fields: [intentId, countryId], references: [id, countryId], onDelete: Restrict)
  country        Country         @relation(fields: [countryId], references: [id], onDelete: Restrict)
  attempts       PayoutAttempt[]
  ledgerEntries  LedgerEntry[]

  @@unique([id, countryId])
  @@unique([intentId, countryId])
  @@index([countryId, profileId, state, createdAt])
  @@map("payout_request")
}

model PayoutAttempt {
  id                 String             @id @default(uuid()) @db.Uuid
  requestId          String             @map("request_id") @db.Uuid
  sequence           Int
  provider           String             @db.VarChar(60)
  providerRequestKey String             @map("provider_request_key") @db.VarChar(160)
  state              PayoutAttemptState @default(QUEUED)
  responseCode       String?            @map("response_code") @db.VarChar(80)
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  resolvedAt         DateTime?          @map("resolved_at") @db.Timestamptz(3)
  request            PayoutRequest      @relation(fields: [requestId], references: [id], onDelete: Restrict)

  @@unique([requestId, sequence])
  @@unique([provider, providerRequestKey])
  @@map("payout_attempt")
}

model AuditEvent {
  id             String       @id @default(uuid()) @db.Uuid
  actorUserId    String       @map("actor_user_id") @db.Uuid
  countryId      String?      @map("country_id") @db.Uuid
  correlationId  String       @map("correlation_id") @db.VarChar(128)
  action         String       @db.VarChar(120)
  aggregateType  String?      @map("aggregate_type") @db.VarChar(80)
  aggregateId    String?      @map("aggregate_id") @db.Uuid
  outcome        AuditOutcome
  reasonCode     String?      @map("reason_code") @db.VarChar(80)
  beforeRedacted Json?        @map("before_redacted")
  afterRedacted  Json?        @map("after_redacted")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  actor          User         @relation(fields: [actorUserId], references: [id], onDelete: Restrict)
  country        Country?     @relation(fields: [countryId], references: [id], onDelete: Restrict)

  @@index([countryId, createdAt, id])
  @@index([aggregateType, aggregateId, createdAt])
  @@map("audit_event")
}

model IdempotencyRecord {
  id             String   @id @default(uuid()) @db.Uuid
  actorUserId    String   @map("actor_user_id") @db.Uuid
  scope          String   @db.VarChar(100)
  key            String   @db.VarChar(128)
  requestHash    String   @map("request_hash") @db.VarChar(128)
  responseStatus Int?     @map("response_status")
  responseBody   Json?    @map("response_body")
  expiresAt      DateTime @map("expires_at") @db.Timestamptz(3)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  actor          User     @relation(fields: [actorUserId], references: [id], onDelete: Cascade)

  @@unique([actorUserId, scope, key])
  @@index([expiresAt])
  @@map("idempotency_record")
}

model ExternalEvent {
  id              String              @id @default(uuid()) @db.Uuid
  countryId       String              @map("country_id") @db.Uuid
  provider        String              @db.VarChar(60)
  externalEventId String              @map("external_event_id") @db.VarChar(180)
  payloadHash     String              @map("payload_hash") @db.VarChar(128)
  status          ExternalEventStatus @default(RECEIVED)
  aggregateType   String?             @map("aggregate_type") @db.VarChar(80)
  aggregateId     String?             @map("aggregate_id") @db.Uuid
  receivedAt      DateTime            @default(now()) @map("received_at") @db.Timestamptz(3)
  appliedAt       DateTime?           @map("applied_at") @db.Timestamptz(3)
  country         Country             @relation(fields: [countryId], references: [id], onDelete: Restrict)

  @@unique([provider, externalEventId])
  @@index([countryId, status, receivedAt])
  @@map("external_event")
}
